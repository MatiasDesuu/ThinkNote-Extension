{
  "manifest_version": 3,
  "name": "ThinkNote Bookmarker",
  "version": "1.0",
  "description": "Save bookmarks and text selections to a WebDAV SQLite database",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "quick-save-bookmark": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Command+Shift+Y"
      },
      "description": "Quick save current page as bookmark"
    },
    "quick-save-think": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save selected text as Think"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/sql-wasm.js",
        "lib/sql-wasm.wasm"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "512": "icons/icon512.png"
    }
  },
  "icons": {
    "512": "icons/icon512.png"
  }
}